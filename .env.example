# NOTE: PORT is NOT set here. The container's internal port is fixed by the Docker
# image (8080) and published on host 5000 by docker-compose. Setting PORT here would
# override the image via env_file and break the 5000:8080 mapping.

# DB Config
TECH_DB_CONNECTION_STRING=postgresql://postgres:password@localhost:5432/tech_dashboard
HOST=localhost
SUPERBASE_HOST=5432
SUPERBASE_DB=tech_dashboard
SUPERBASE_USER=postgres

# JWT Config — generate strong random values: openssl rand -base64 48
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
