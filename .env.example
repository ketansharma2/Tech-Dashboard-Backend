# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Comma-separated list of browser origins allowed by CORS (no hardcoded localhost
# in code anymore — CHANGELOG M3). e.g. https://dashboard.example.com
CORS_ORIGIN=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Single source of truth for the DB connection. Add ?sslmode=require for managed
# Postgres (RDS / Supabase). The legacy HOST / SUPERBASE_* vars were removed — they
# were unused and duplicated this string. (CHANGELOG L6)
TECH_DB_CONNECTION_STRING=postgresql://postgres:password@localhost:5432/tech_dashboard?sslmode=require

# Max pooled DB connections per app instance ≈ (DB max_connections / #instances).
DB_POOL_MAX=10

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED — the app refuses to boot if these are missing (no default fallback).
# Generate strong values:  openssl rand -base64 48   (CHANGELOG H2)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Migrations ──────────────────────────────────────────────────────────────
# Keep false in production: migrations are applied by the deploy pipeline as a
# gated step before the swap, NOT on app boot. (CHANGELOG H1)
RUN_MIGRATIONS=false

# ─── AWS ─────────────────────────────────────────────────────────────────────
# DO NOT store static AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here. The app uses
# no AWS SDK today; if it ever needs S3 etc., grant access via the EC2 instance
# role at runtime and OIDC in CI — never long-lived keys in a file. (CHANGELOG H3)
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=my-bucket
